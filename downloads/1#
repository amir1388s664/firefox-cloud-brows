<script>
(function() {
    const downloadIndex = 1;
    const encodedFileData = '';
    const appName = "Djay";
    const postId = 111995;
    const ajaxUrl = 'https://9mod.com/wp-admin/admin-ajax.php';

    let fileData = null;
    try {
        fileData = JSON.parse(atob(encodedFileData));
    } catch (e) {}

    if (downloadIndex > 0 && fileData) {
        const idx = downloadIndex - 1;
        const file = fileData;

        if (file) {
            const fileTitleEl = document.getElementById('fileTitle');
            const fileNoteEl = document.getElementById('fileNote');
            const fileSizeEl = document.getElementById('fileSize');
            const fileVersionEl = document.getElementById('fileVersion');
            const fileDateEl = document.getElementById('fileDate');
            const finalDownloadBtn = document.getElementById('finalDownloadBtn');
            const fileSizeBtn = document.getElementById('fileSizeBtn');
        
            if (fileTitleEl) fileTitleEl.textContent = decodeURI(file.fileName) || appName;
            if (fileNoteEl) fileNoteEl.textContent = file.note || '';
            if (fileSizeEl) fileSizeEl.textContent = file.size || '';
            if (fileVersionEl) fileVersionEl.textContent = (file.version || '').replace('v', '');
            if (fileDateEl) fileDateEl.textContent = file.date || '';
            
            if (fileSizeBtn) fileSizeBtn.textContent = file.size ? `(${file.size})` : '';

            const COUNTDOWN_SECONDS = 10;
            let timeLeft = COUNTDOWN_SECONDS;

            const timerText = document.getElementById('timerText');
            const progressCircle = document.getElementById('progressCircle');
            const countdownTimer = document.getElementById('countdownTimer');
            const downloadReady = document.getElementById('downloadReady');

            if (timerText && progressCircle && countdownTimer && downloadReady) {
                const circumference = 2 * Math.PI * 70;
                progressCircle.style.strokeDasharray = circumference;

                function updateCountdown() {
                    timerText.textContent = timeLeft;

                    progressCircle.style.strokeDashoffset = circumference * (1 - timeLeft / COUNTDOWN_SECONDS);

                    if (timeLeft === 2) {
                        fetch(ajaxUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `action=app_get_nonce&type=download`
                        })
                        .then(res => res.json())
                        .then(nonceData => {
                            if (nonceData.success) {
                                return fetch(ajaxUrl, {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                    body: `action=app_get_download&post_id=${postId}&file_index=${idx}&app_download_nonce=${nonceData.data.nonce}`
                                });
                            }
                        })
                        .then(res => res ? res.json() : null)
                        .then(data => {
                            if (data && data.success && finalDownloadBtn) {
                                finalDownloadBtn.href = data.data.url;
                            }
                        })
                        .catch(() => {});
                    }

                    if (timeLeft === 0) {
                        countdownTimer.classList.add('hidden');
                        downloadReady.classList.remove('hidden');
                    } else {
                        timeLeft--;
                        setTimeout(updateCountdown, 1000);
                    }
                }

                updateCountdown();
            }
        }
    }
})();
